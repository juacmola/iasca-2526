        }
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "(28, 28, 3)\n",
            "(1, 2352)\n"
          ]
        }
      ],
      "source": [
        "imgdata = np.asarray(imgprocessed, dtype=\"uint8\")\n",
        "print(imgdata.shape)\n",
        "imgdata = imgdata.reshape(1, -1)\n",
        "print(imgdata.shape)\n",
        "size = 28 * 28 * 3\n",
        "\n",
        "row = pd.DataFrame(imgdata, columns=['pixel'+str(i) for i in range(size)])\n",
        "row_scaled = scaler.transform(row) # remember that we trained our models with standarized data"
      ]
    },
