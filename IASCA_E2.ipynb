      "source": [
        "from PIL import ImageOps\n",
        "\n",
        "border = (58, 2, 58, 2) # left, top, right, bottom\n",
        "imgprocessed = ImageOps.crop(img, border)\n",
        "imgprocessed = img.resize((28, 28))\n",
        "\n",
        "plt.imshow(imgprocessed)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "PjqaxcHQqrV-"
      },
      "source": [
        "OK, the image has the format we wanted, but it is not still the NumPy array that out model expects. Let's do it."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "NUlsC-4FqrV_",
        "outputId": "b319ef48-6780-433f-e0e1-f6d6f32a316a",
        "colab": {
