      "source": [
        "KNN - Muestro una gráfica donde se ve el valor de accuracy dependiendo del valor de k"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#https://www.datacamp.com/tutorial/k-nearest-neighbor-classification-scikit-learn\n",
        "k_values = [i for i in range (1,15)]\n",
        "scores = []\n",
        "\n",
        "for k in k_values:\n",
        "    knn = KNeighborsClassifier(n_neighbors=k)\n",
        "    score = model_selection.cross_val_score(knn, X, y, cv=10)\n",
