      "metadata": {
        "id": "YrWufsE0qrVr"
      },
      "source": [
        "We split our data into train and test datasets."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 14,
      "metadata": {
        "id": "WffqsKn7qrVt",
